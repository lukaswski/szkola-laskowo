---
import { Image } from 'astro:assets';
import { HOME } from '../content';

const mods = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/hero/*.{jpg,jpeg,png,webp}',
  { eager: true }
);
const images = Object.values(mods).map(m => m.default);
---

<section class="hero-section">

  <!-- ── IMAGE PANEL (right, diagonal clip) ──────────── -->
  <div class="image-panel">
    {images.map((img, i) => (
      <div class:list={['hero-slide', { active: i === 0 }]}>
        <Image
          src={img}
          alt={`Szkoła Podstawowa w Laskowie — zdjęcie ${i + 1}`}
          width={1200}
          height={900}
          class="w-full h-full object-cover object-[center_30%]"
          loading={i === 0 ? 'eager' : 'lazy'}
        />
      </div>
    ))}

    <!-- Carousel dots -->
    <div id="hero-dots">
      {images.map((_, i) => (
        <button
          class:list={['hero-dot', { active: i === 0 }]}
          data-slide={i}
          aria-label={`Zdjęcie ${i + 1}`}
        />
      ))}
    </div>
  </div>

  <!-- ── TEXT PANEL (left) ─────────────────────────── -->
  <div class="text-panel">
    <div class="text-inner">

      <!-- top: tylko h1 — na mobile pojawia się nad sliderem -->
      <div class="text-top">
        <h1>
          {HOME.hero.headingLine1}<br/>
          <span class="heading-accent">{HOME.hero.headingLine2}</span>
        </h1>
      </div>

      <!-- bottom: badge + opis + CTA — na mobile pod sliderem -->
      <div class="text-bottom">
        <div class="badge">
          <span class="badge-dot"></span>
          {HOME.hero.badge}
        </div>

        <p>{HOME.hero.subheading}</p>

        <div class="ctas">
          <a href="/aktualnosci" class="btn-primary">
            {HOME.hero.ctaNews}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a href="/about" class="btn-outline">{HOME.hero.ctaAbout}</a>
        </div>
      </div>

    </div>
  </div>

</section>

<style>
  /* ── Section ─────────────────────────────────────────── */
  .hero-section {
    position: relative;
    min-height: 600px;
    overflow: hidden;
    background: linear-gradient(135deg,
      var(--color-school-50) 0%,
      #ffffff 55%,
      var(--color-lemon-100) 100%
    );
  }

  /* ── Image panel ─────────────────────────────────────── */
  .image-panel {
    position: absolute;
    inset: 0;
    /* "/" diagonal: left edge goes from ~42% at top to ~30% at bottom */
    clip-path: polygon(54% 0, 100% 0, 100% 100%, 44% 100%);
    z-index: 0;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero-slide.active { opacity: 1; }

  /* zielonkawy overlay */
  .image-panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: color-mix(in oklch, var(--color-school-600) 30%, rgba(0,0,0,0.10));
    pointer-events: none;
    z-index: 1;
  }

  /* Dots */
  #hero-dots {
    position: absolute;
    bottom: 28px;
    right: 36px;
    display: flex;
    gap: 7px;
    z-index: 2;
  }

  .hero-dot {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: var(--color-school-200);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: width 0.3s ease, background 0.3s ease;
  }

  .hero-dot.active {
    width: 24px;
    background: var(--color-school-500);
  }

  .hero-dot:hover:not(.active) {
    background: var(--color-school-300);
  }

  /* ── Text panel ──────────────────────────────────────── */
  .text-panel {
    position: relative;
    z-index: 1;
    min-height: 600px;
    display: flex;
    align-items: center;
    width: 52%;
    padding: 0 1rem 0 0;
  }

  .text-inner {
    width: 100%;
    max-width: 520px;
    padding-left: clamp(4rem, 12vw, 12rem);
  }

  /* Badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    background: var(--color-school-100);
    color: var(--color-school-700);
    font-size: 0.75rem;
    font-weight: 600;
    margin-top: 0;
    margin-bottom: 1.5rem;
    border: 1px solid color-mix(in oklch, var(--color-school-200) 60%, transparent);
  }

  .badge-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-school-500);
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Heading */
  h1 {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.05;
    color: var(--color-school-900);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .heading-accent {
    background: linear-gradient(to right,
      var(--color-school-600),
      var(--color-school-500),
      var(--color-lemon-500)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subheading */
  p {
    font-size: 1.1rem;
    color: color-mix(in oklch, var(--color-school-700) 75%, transparent);
    max-width: 420px;
    line-height: 1.65;
    margin-bottom: 2.5rem;
  }

  /* CTAs */
  .ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: 0.75rem;
    background: var(--color-school-600);
    color: #fff;
    font-weight: 600;
    font-size: 0.875rem;
    box-shadow: 0 4px 16px -4px color-mix(in oklch, var(--color-school-600) 40%, transparent);
    transition: background 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }

  .btn-primary:hover {
    background: var(--color-school-700);
    box-shadow: 0 6px 20px -4px color-mix(in oklch, var(--color-school-600) 50%, transparent);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: 0.75rem;
    border: 2px solid var(--color-school-200);
    color: var(--color-school-700);
    font-weight: 600;
    font-size: 0.875rem;
    transition: background 0.2s, border-color 0.2s;
    text-decoration: none;
  }

  .btn-outline:hover {
    background: var(--color-school-50);
    border-color: var(--color-school-300);
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .hero-section {
      min-height: auto;
      display: grid;
      grid-template-rows: 360px auto;
    }

    /* image i h1 nakładają się w tej samej komórce gridu */
    .image-panel {
      grid-row: 1;
      grid-column: 1;
      position: relative;
      height: auto;
      clip-path: none;
    }


    .text-panel {
      position: static;
      width: 100%;
      min-height: auto;
      padding: 0;
      display: contents;
    }

    .text-inner {
      max-width: 100%;
      padding-left: 0;
      display: contents;
    }

    /* h1 lewituje na zdjęciu — ta sama komórka gridu */
    .text-top {
      grid-row: 1;
      grid-column: 1;
      position: relative;
      z-index: 10;
      display: flex;
      align-items: center;
      padding: 1.25rem 1.5rem;
    }

    .text-top h1 {
      color: #ffffff;
      text-shadow: 0 2px 16px rgba(0,0,0,0.3);
    }

    .text-top .heading-accent {
      background: none;
      -webkit-text-fill-color: #ffffff;
    }

    /* badge + opis + CTA pod sliderem */
    .text-bottom {
      grid-row: 2;
      grid-column: 1;
      padding: 1.5rem 1.5rem 2rem;
    }
  }

  @media (max-width: 639px) {
    .hero-section { grid-template-rows: 280px auto; }

    .text-top h1 { font-size: 2.25rem; }

    #hero-dots {
      bottom: 16px;
      right: 50%;
      transform: translateX(50%);
    }
  }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
  const dots   = document.querySelectorAll<HTMLElement>('.hero-dot');
  let cur = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(n: number) {
    slides[cur].classList.remove('active');
    dots[cur]?.classList.remove('active');
    cur = ((n % slides.length) + slides.length) % slides.length;
    slides[cur].classList.add('active');
    dots[cur]?.classList.add('active');
  }

  function startAuto() {
    timer = setInterval(() => goTo(cur + 1), 4500);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(i);
      startAuto();
    });
  });

  startAuto();
</script>
