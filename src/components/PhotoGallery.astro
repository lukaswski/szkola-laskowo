---
interface ImageItem {
  src: string;
  alt?: string;
}

interface Props {
  images: ImageItem[];
}

const { images } = Astro.props;
const id = `gallery-${Math.random().toString(36).slice(2, 7)}`;
---

<div class="photo-gallery" id={id}>
  {images.map((img, i) => (
    <button
      class:list={[
        'tile',
        i === 0 ? 'tile-hero' : '',
        i === 4 && images.length > 5 ? 'tile-wide' : '',
      ]}
      data-index={i}
      aria-label={img.alt ?? `Zdjęcie ${i + 1}`}
    >
      <img src={img.src} alt={img.alt ?? ''} loading="lazy" />
    </button>
  ))}
</div>

<!-- Lightbox -->
<div class="lb-backdrop" id={`${id}-lb`} aria-modal="true" role="dialog" hidden>
  <button class="lb-close" aria-label="Zamknij">&#x2715;</button>
  <button class="lb-prev" aria-label="Poprzednie">&#x2039;</button>
  <button class="lb-next" aria-label="Następne">&#x203A;</button>
  <div class="lb-img-wrap">
    <img class="lb-img" src="" alt="" />
  </div>
  <div class="lb-counter"></div>
</div>

<style>
  /* ── Gallery grid ─────────────────────────────────────── */
  .photo-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 180px;
    gap: 6px;
    margin-block: 2rem;
  }

  .tile {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    background: oklch(0.94 0.050 130);
    cursor: zoom-in;
    border: none;
    padding: 0;
  }

  .tile img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    pointer-events: none;
  }

  .tile:hover img {
    transform: scale(1.06);
  }

  .tile-hero {
    grid-column: span 2;
    grid-row: span 2;
  }

  .tile-wide {
    grid-column: span 2;
  }

  @media (max-width: 520px) {
    .photo-gallery {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 130px;
    }
    .tile-hero { grid-column: span 2; grid-row: span 1; }
    .tile-wide  { grid-column: span 2; }
  }

  /* ── Lightbox ─────────────────────────────────────────── */
  .lb-backdrop {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0 0 0 / 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .lb-backdrop:not([hidden]) {
    display: flex;
  }

  .lb-backdrop.lb-visible {
    opacity: 1;
  }

  .lb-img-wrap {
    max-width: 92vw;
    max-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb-img {
    max-width: 92vw;
    max-height: 88vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 10px;
    box-shadow: 0 24px 80px rgba(0 0 0 / 0.6);
    transition: opacity 0.2s ease;
  }

  .lb-img.lb-loading {
    opacity: 0;
  }

  .lb-close,
  .lb-prev,
  .lb-next {
    position: fixed;
    background: rgba(255 255 255 / 0.12);
    border: none;
    color: #fff;
    cursor: pointer;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    line-height: 1;
    transition: background 0.2s;
    backdrop-filter: blur(4px);
  }

  .lb-close:hover,
  .lb-prev:hover,
  .lb-next:hover {
    background: rgba(255 255 255 / 0.25);
  }

  .lb-close { top: 18px; right: 18px; font-size: 16px; }
  .lb-prev  { left: 14px; top: 50%; transform: translateY(-50%); font-size: 30px; }
  .lb-next  { right: 14px; top: 50%; transform: translateY(-50%); font-size: 30px; }

  .lb-counter {
    position: fixed;
    bottom: 18px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255 255 255 / 0.6);
    font-size: 13px;
    font-family: system-ui, sans-serif;
    letter-spacing: 0.05em;
  }

  @media (max-width: 520px) {
    .lb-prev { left: 6px; }
    .lb-next { right: 6px; }
  }
</style>

<script define:vars={{ id, images }}>
  const gallery = document.getElementById(id);
  const lb      = document.getElementById(`${id}-lb`);
  const lbImg   = lb.querySelector('.lb-img');
  const counter = lb.querySelector('.lb-counter');
  let current   = 0;

  function show(index) {
    current = (index + images.length) % images.length;
    lbImg.classList.add('lb-loading');
    const next = new Image();
    next.onload = () => {
      lbImg.src = images[current].src;
      lbImg.alt = images[current].alt ?? '';
      lbImg.classList.remove('lb-loading');
    };
    next.src = images[current].src;
    counter.textContent = `${current + 1} / ${images.length}`;
  }

  function open(index) {
    lb.hidden = false;
    requestAnimationFrame(() => lb.classList.add('lb-visible'));
    document.body.style.overflow = 'hidden';
    show(index);
  }

  function close() {
    lb.classList.remove('lb-visible');
    lb.addEventListener('transitionend', () => {
      lb.hidden = true;
      document.body.style.overflow = '';
    }, { once: true });
  }

  gallery.querySelectorAll('.tile').forEach(btn => {
    btn.addEventListener('click', () => open(Number(btn.dataset.index)));
  });

  lb.querySelector('.lb-close').addEventListener('click', close);
  lb.querySelector('.lb-prev').addEventListener('click', () => show(current - 1));
  lb.querySelector('.lb-next').addEventListener('click', () => show(current + 1));

  lb.addEventListener('click', e => { if (e.target === lb) close(); });

  document.addEventListener('keydown', e => {
    if (lb.hidden) return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft')  show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>
