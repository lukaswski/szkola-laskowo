---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Strona główna</HeaderLink>
			<HeaderLink href="/aktualnosci">Aktualności</HeaderLink>
			<HeaderLink href="/about">O szkole</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--accent-dark);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 20%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #fff;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.75em;
		color: rgba(255, 255, 255, 0.85);
		border-bottom: 3px solid transparent;
		text-decoration: none;
	}
	nav a:hover {
		color: #fff;
	}
	nav a.active {
		color: #fff;
		border-bottom-color: #fff;
	}
	@media (max-width: 720px) {
		h2 {
			font-size: 0.85em;
		}
	}
</style>
