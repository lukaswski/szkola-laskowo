---
import { ABOUT_PAGE, CONTACT, NAV, SITE } from '../content';
const today = new Date();
---

<footer class="bg-school-900 text-white/80">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-14 pb-10">
    <div class="grid md:grid-cols-[2fr_1fr_1fr] gap-10">

      <!-- Brand -->
      <div>
        <a href="/" class="inline-flex items-center gap-2.5 mb-5 group">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-school-300 to-school-600 flex items-center justify-center shadow group-hover:shadow-md transition-shadow shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <div class="flex flex-col gap-[2px]">
            <span class="block text-[12px] font-bold text-white tracking-normal leading-none">{SITE.nameLine1}</span>
            <span class="block text-[12px] font-bold text-white tracking-normal leading-none">{SITE.nameLine2}</span>
            <span class="block text-[12px] font-semibold text-school-300 tracking-normal leading-none">{SITE.nameLine3}</span>
          </div>
        </a>
        <p class="text-sm text-white/70 mb-2 leading-snug">Dyrekcja:<br/><span class="text-white/90">{ABOUT_PAGE.staff.directorName}</span></p>
        <p class="text-sm text-white/70 mb-2 leading-snug">Organ prowadzący:<br/><span class="text-white/90">{ABOUT_PAGE.organizer}</span></p>
        <p class="text-sm text-white/50 leading-relaxed max-w-[260px]">
          {SITE.description}
        </p>
      </div>

      <!-- Links -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Menu</p>
        <ul class="space-y-2.5 text-sm">
          {NAV.map((item) => (
            <li>
              <a href={item.href} class="hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-white/40 mb-4">Kontakt</p>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-school-400">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <div class="flex flex-col leading-snug">
              <span>{CONTACT.addressLine1}</span>
              <span>{CONTACT.addressLine2}</span>
            </div>
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-school-400">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11.8a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.55 5.55l.98-.99a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 15l.92 1.92Z"/>
            </svg>
            <a href={`tel:${CONTACT.phone.replace(/\s/g,'')}`} class="hover:text-white transition-colors">{CONTACT.phone}</a>
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-school-400">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href={`mailto:${CONTACT.email}`} class="hover:text-white transition-colors">{CONTACT.email}</a>
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="shrink-0 text-school-400">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
            <a href="https://www.facebook.com/sp.laskowo" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Facebook</a>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 text-center text-xs text-white/30">
      &copy; {today.getFullYear()} {SITE.title}. Wszelkie prawa zastrzeżone.
    </div>
  </div>
</footer>
