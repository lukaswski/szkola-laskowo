---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { ABOUT_PAGE } from '../content';

const dokumenty = [
  {
    nazwa: 'Karta zapisu dziecka do klasy pierwszej',
    opis: 'Formularz zapisu dziecka do pierwszej klasy szkoły podstawowej.',
    file: '/dokumenty/karta-zapisu-klasa-pierwsza.docx',
    typ: 'DOCX',
  },
  {
    nazwa: 'Klauzula informacyjna RODO — rekrutacja',
    opis: 'Informacja o przetwarzaniu danych osobowych w związku z rekrutacją do szkoły podstawowej.',
    file: '/dokumenty/klauzula-rodo-rekrutacja.pdf',
    typ: 'PDF',
  },
];
---

<html lang="pl">
  <head>
    <BaseHead title={ABOUT_PAGE.meta.title} description={ABOUT_PAGE.meta.description} />
  </head>
  <body>
    <Header />

    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">

      <div class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-school-500 mb-2">Rok szkolny 2025/2026</p>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-school-900 leading-tight">{ABOUT_PAGE.meta.title}</h1>
        <p class="mt-3 text-school-600 max-w-xl">Dokumenty szkolne i inne materiały do pobrania.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-14">
        {dokumenty.map((d) => (
          <a
            href={d.file}
            download
            class="group text-left rounded-xl border border-school-200 bg-white hover:border-school-400 hover:shadow-md transition-all duration-200 px-5 py-4 flex items-start gap-4"
          >
            <div class="w-10 h-10 rounded-lg bg-school-50 group-hover:bg-school-100 flex items-center justify-center shrink-0 transition-colors mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-school-600">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-school-900 text-sm leading-tight">{d.nazwa}</div>
              <div class="text-xs text-school-500 mt-1 leading-relaxed">{d.opis}</div>
              <div class="text-xs font-medium text-school-400 mt-2">{d.typ} · pobierz</div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-school-400 group-hover:text-school-600 shrink-0 transition-colors mt-1">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
          </a>
        ))}
      </div>

    </div>

    <Footer />
  </body>
</html>
