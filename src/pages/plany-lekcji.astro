---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const plans = [
  { klasa: 'Klasa 1A', file: '/plan/Dziennik_1A (NSP) 2025_2026_TygodniowyPlanZajec.pdf' },
  { klasa: 'Klasa 2A', file: '/plan/Dziennik_2A (NSP) 2025_2026_TygodniowyPlanZajec.pdf' },
  { klasa: 'Klasa 4A', file: '/plan/Dziennik_4A (NSP) 2025_2026_TygodniowyPlanZajec.pdf' },
  { klasa: 'Klasa 6A', file: '/plan/Dziennik_6A (NSP) 2025_2026_TygodniowyPlanZajec.pdf' },
  { klasa: 'Klasa 7A', file: '/plan/Dziennik_7A (NSP) 2025_2026_TygodniowyPlanZajec.pdf' },
  { klasa: 'Klasa 8A', file: '/plan/Dziennik_8A (NSP) 2025_2026_TygodniowyPlanZajec.pdf' },
];
---

<html lang="pl">
  <head>
    <BaseHead title="Plany lekcji" description="Tygodniowe plany zajęć dla poszczególnych klas — rok szkolny 2025/2026." />
  </head>
  <body>
    <Header />

    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">

      <!-- Nagłówek sekcji -->
      <div class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-school-500 mb-2">Rok szkolny 2025/2026</p>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-school-900 leading-tight">Plany lekcji</h1>
        <p class="mt-3 text-school-600 max-w-xl">Tygodniowe plany zajęć dla poszczególnych klas. Kliknij na klasę, aby otworzyć plan, lub pobierz plik PDF.</p>
      </div>

      <!-- Karty klas -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 sm:gap-4 mb-14" id="plan-grid">
        {plans.map((p) => (
          <button
            data-file={p.file}
            data-klasa={p.klasa}
            class="plan-btn group text-left rounded-xl border border-school-200 bg-white hover:border-school-400 hover:shadow-md transition-all duration-200 px-4 py-3 flex items-center gap-3"
          >
            <div class="w-8 h-8 rounded-lg bg-school-50 group-hover:bg-school-100 flex items-center justify-center shrink-0 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-school-600">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-school-900 text-sm leading-tight">{p.klasa}</div>
              <div class="text-xs text-school-500 mt-0.5">Plan tygodniowy</div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-school-400 group-hover:text-school-600 shrink-0 transition-colors">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>
        ))}
      </div>

      <!-- Podgląd PDF -->
      <div id="pdf-viewer" class="hidden">
        <div class="flex items-center justify-between mb-4">
          <h2 id="pdf-title" class="text-xl font-bold text-school-900"></h2>
          <div class="flex items-center gap-3">
            <a
              id="pdf-download"
              href="#"
              download
              class="inline-flex items-center gap-2 text-sm font-semibold text-school-600 hover:text-school-800 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Pobierz PDF
            </a>
            <button
              id="pdf-close"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-school-500 hover:text-school-800 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
              Zamknij
            </button>
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden border border-school-200 bg-school-50">
          <iframe
            id="pdf-frame"
            src=""
            class="w-full"
            style="height: 80vh; min-height: 500px;"
            title="Plan lekcji"
          ></iframe>
        </div>
      </div>

    </div>

    <Footer />
  </body>
</html>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.plan-btn');
  const viewer = document.getElementById('pdf-viewer')!;
  const frame = document.getElementById('pdf-frame') as HTMLIFrameElement;
  const title = document.getElementById('pdf-title')!;
  const download = document.getElementById('pdf-download') as HTMLAnchorElement;
  const closeBtn = document.getElementById('pdf-close')!;

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const file = btn.dataset.file!;
      const klasa = btn.dataset.klasa!;

      title.textContent = klasa;
      frame.src = file;
      download.href = file;

      viewer.classList.remove('hidden');
      viewer.scrollIntoView({ behavior: 'smooth', block: 'start' });

      buttons.forEach((b) => b.classList.remove('ring-2', 'ring-school-400'));
      btn.classList.add('ring-2', 'ring-school-400');
    });
  });

  closeBtn.addEventListener('click', () => {
    viewer.classList.add('hidden');
    frame.src = '';
    buttons.forEach((b) => b.classList.remove('ring-2', 'ring-school-400'));
  });
</script>
