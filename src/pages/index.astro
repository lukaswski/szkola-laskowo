---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const stats = [
  { value: '40+', label: 'lat tradycji' },
  { value: '320', label: 'uczniów' },
  { value: '28', label: 'nauczycieli' },
  { value: '8', label: 'klas' },
];

const values = [
  {
    title: 'Nowoczesne nauczanie',
    desc: 'Łączymy tradycję z nowoczesnością — metody dopasowane do potrzeb każdego ucznia.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  },
  {
    title: 'Bezpieczne środowisko',
    desc: 'Tworzymy przyjazną i bezpieczną przestrzeń, w której każde dziecko może się rozwijać.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: 'Wszechstronny rozwój',
    desc: 'Sport, kultura, nauka — wspieramy pasje uczniów na każdym polu aktywności.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
];
---

<!doctype html>
<html lang="pl">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <!-- ── HERO ─────────────────────────────────────────────── -->
    <section class="relative overflow-hidden bg-gradient-to-br from-school-50 via-white to-lemon-100 pt-24 pb-28">
      <!-- decorative blobs -->
      <div class="pointer-events-none absolute -top-32 -right-32 w-[520px] h-[520px] rounded-full bg-school-200/30 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-24 -left-20 w-[380px] h-[380px] rounded-full bg-lemon-200/25 blur-3xl"></div>

      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 text-center">

        <!-- badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-school-100 text-school-700 text-xs font-semibold mb-8 border border-school-200/60">
          <span class="w-1.5 h-1.5 rounded-full bg-school-500 animate-pulse"></span>
          Rok szkolny 2024/2025
        </div>

        <!-- heading -->
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-school-900 leading-[1.05] mb-6 tracking-tight">
          Witamy w<br/>
          <span class="bg-gradient-to-r from-school-600 via-school-500 to-lemon-500 bg-clip-text text-transparent">
            Szkole Podstawowej
          </span><br/>
          w Laskowie
        </h1>

        <p class="text-lg text-school-700/75 max-w-lg mx-auto mb-10 leading-relaxed">
          Miejsce, gdzie uczniowie rozwijają pasje, zdobywają wiedzę
          i tworzą przyjaźnie na całe życie.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 justify-center">
          <a
            href="/aktualnosci"
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl bg-school-600 text-white font-semibold text-sm shadow-md shadow-school-600/25 hover:bg-school-700 hover:shadow-lg hover:shadow-school-600/30 transition-all"
          >
            Aktualności
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/about"
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl border-2 border-school-200 text-school-700 font-semibold text-sm hover:bg-school-50 hover:border-school-300 transition-all"
          >
            O szkole
          </a>
        </div>

      </div>
    </section>

    <!-- ── STATS ──────────────────────────────────────────────── -->
    <section class="bg-gradient-to-r from-school-700 to-school-600 py-12">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
          {stats.map((s) => (
            <div>
              <div class="text-4xl font-extrabold text-lemon-300 tracking-tight">{s.value}</div>
              <div class="text-sm text-white/60 mt-1 font-medium">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── NEWS ──────────────────────────────────────────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">

        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="text-school-500 font-semibold text-xs uppercase tracking-widest mb-2">Co nowego?</p>
            <h2 class="text-3xl font-extrabold text-school-900">Ostatnie aktualności</h2>
          </div>
          <a href="/aktualnosci" class="flex items-center gap-1.5 text-school-600 font-semibold text-sm hover:text-school-700 transition-colors">
            Wszystkie
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {posts.map((post) => (
            <a
              href={`/aktualnosci/${post.id}/`}
              class="group flex flex-col rounded-2xl border border-school-100 bg-white p-6 hover:border-school-200 hover:shadow-xl hover:shadow-school-100/60 transition-all duration-200"
            >
              <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-lemon-100 text-school-700 text-xs font-semibold mb-4 self-start border border-lemon-200/60">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                <FormattedDate date={post.data.pubDate} />
              </div>

              <h3 class="font-bold text-school-900 text-[1.05rem] mb-2 leading-snug group-hover:text-school-600 transition-colors">
                {post.data.title}
              </h3>

              {post.data.description && (
                <p class="text-school-700/60 text-sm leading-relaxed flex-1 line-clamp-3">
                  {post.data.description}
                </p>
              )}

              <div class="mt-5 flex items-center gap-1.5 text-school-500 font-semibold text-sm group-hover:gap-2.5 transition-all">
                Czytaj więcej
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>

      </div>
    </section>

    <!-- ── VALUES ─────────────────────────────────────────────── -->
    <section class="py-20 bg-school-50/60">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">

        <div class="text-center mb-14">
          <p class="text-school-500 font-semibold text-xs uppercase tracking-widest mb-2">Nasze wartości</p>
          <h2 class="text-3xl font-extrabold text-school-900">Dlaczego warto być z nami?</h2>
        </div>

        <div class="grid sm:grid-cols-3 gap-8">
          {values.map((v) => (
            <div class="bg-white rounded-2xl p-8 border border-school-100 flex flex-col items-center text-center hover:shadow-lg hover:shadow-school-100/50 transition-shadow">
              <div class="w-16 h-16 rounded-2xl bg-school-100 flex items-center justify-center text-school-600 mb-5">
                <Fragment set:html={v.icon} />
              </div>
              <h3 class="font-bold text-school-900 text-lg mb-3">{v.title}</h3>
              <p class="text-school-700/65 text-sm leading-relaxed">{v.desc}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ── CTA BANNER ─────────────────────────────────────────── -->
    <section class="py-16 bg-white border-t border-school-100">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-2xl font-extrabold text-school-900 mb-3">Masz pytania?</h2>
        <p class="text-school-700/70 text-sm mb-7">Sekretariat czynny pon.–pt. w godz. 7:30–15:30. Zapraszamy do kontaktu.</p>
        <a
          href="mailto:sekretariat@sp-laskowo.pl"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl bg-school-600 text-white font-semibold text-sm shadow-md shadow-school-600/20 hover:bg-school-700 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Napisz do nas
        </a>
      </div>
    </section>

    <Footer />
  </body>
</html>
