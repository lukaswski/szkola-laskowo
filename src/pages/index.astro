---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="pl">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Witamy w naszej szkole!</h1>
				<p>
					Szkoła Podstawowa w Laskowie to miejsce, gdzie uczniowie rozwijają swoje pasje,
					zdobywają wiedzę i tworzą przyjaźnie na całe życie.
				</p>
				<a href="/blog" class="btn">Zobacz aktualności</a>
			</section>

			<section class="aktualnosci">
				<h2>Ostatnie aktualności</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="data">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<h3>{post.data.title}</h3>
									{post.data.description && <p>{post.data.description}</p>}
								</a>
							</li>
						))
					}
				</ul>
				<a href="/blog" class="wiecej">Wszystkie aktualności →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.hero {
		text-align: center;
		padding: 3em 1em 2em;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2em;
	}
	.hero h1 {
		font-size: 2.5em;
		color: var(--accent-dark);
	}
	.hero p {
		font-size: 1.1em;
		color: rgb(var(--gray));
		max-width: 560px;
		margin: 0 auto 1.5em;
	}
	.btn {
		display: inline-block;
		background: var(--accent);
		color: #fff;
		padding: 0.6em 1.6em;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 700;
	}
	.btn:hover {
		background: var(--accent-dark);
	}
	.aktualnosci h2 {
		font-size: 1.5em;
		margin-bottom: 1em;
		color: var(--accent-dark);
	}
	ul {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5em;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	ul li a {
		display: block;
		padding: 1em 1.25em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		transition: box-shadow 0.2s;
	}
	ul li a:hover {
		box-shadow: var(--box-shadow);
	}
	.data {
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	ul li h3 {
		margin: 0.2em 0 0.3em;
		font-size: 1.1em;
		color: rgb(var(--black));
	}
	ul li p {
		margin: 0;
		font-size: 0.95em;
		color: rgb(var(--gray));
	}
	.wiecej {
		color: var(--accent);
		font-weight: 700;
	}
</style>
