---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { NEWS_PAGE, SITE } from '../../content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="pl">
  <head>
    <BaseHead
      title={`${NEWS_PAGE.meta.title} — ${SITE.title}`}
      description={NEWS_PAGE.meta.description}
    />
  </head>
  <body>
    <Header />

    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16">

      <!-- page header -->
      <div class="mb-12">
        <p class="text-school-500 font-semibold text-xs uppercase tracking-widest mb-2">{NEWS_PAGE.eyebrow}</p>
        <h1 class="text-4xl font-extrabold text-school-900">{NEWS_PAGE.heading}</h1>
      </div>

      <!-- list -->
      <ul class="flex flex-col gap-4">
        {posts.map((post) => (
          <li>
            <a
              href={`/aktualnosci/${post.id}/`}
              class="group flex flex-col sm:flex-row sm:items-start gap-4 rounded-2xl border border-school-100 bg-white p-6 hover:border-school-200 hover:shadow-xl hover:shadow-school-100/50 transition-all duration-200"
            >
              <!-- date badge -->
              <div class="sm:pt-0.5 shrink-0">
                <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-lemon-100 text-school-700 text-xs font-semibold border border-lemon-200/60 whitespace-nowrap">
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                  <FormattedDate date={post.data.pubDate} />
                </div>
              </div>

              <!-- content -->
              <div class="flex-1 min-w-0">
                <h2 class="font-bold text-school-900 text-lg leading-snug mb-1.5 group-hover:text-school-600 transition-colors">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="text-school-700/60 text-sm leading-relaxed line-clamp-2">
                    {post.data.description}
                  </p>
                )}
              </div>

              <!-- arrow -->
              <div class="text-school-400 group-hover:text-school-600 group-hover:translate-x-1 transition-all shrink-0 self-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>
            </a>
          </li>
        ))}
      </ul>

    </div>

    <Footer />
  </body>
</html>
