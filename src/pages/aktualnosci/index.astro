---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { HOME, NEWS_PAGE, SITE } from '../../content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="pl">
  <head>
    <BaseHead
      title={`${NEWS_PAGE.meta.title} — ${SITE.title}`}
      description={NEWS_PAGE.meta.description}
    />
  </head>
  <body>
    <Header />

    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">

      <!-- page header -->
      <div class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-school-500 mb-2">Rok szkolny 2025/2026</p>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-school-900 leading-tight">{NEWS_PAGE.heading}</h1>
        <p class="mt-3 text-school-600 max-w-xl">{NEWS_PAGE.meta.description}</p>
      </div>

      <!-- grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {posts.map((post) => (
          <a
            href={`/aktualnosci/${post.id}/`}
            class="group flex flex-col rounded-2xl border border-school-100 bg-white p-6 hover:border-school-200 hover:shadow-xl hover:shadow-school-100/60 transition-all duration-200"
          >
            <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-lemon-100 text-school-700 text-xs font-semibold mb-4 self-start border border-lemon-200/60">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              <FormattedDate date={post.data.pubDate} />
            </div>

            <h2 class="font-bold text-school-900 text-[1.05rem] mb-2 leading-snug group-hover:text-school-600 transition-colors">
              {post.data.title}
            </h2>

            {post.data.description && (
              <p class="text-school-700/60 text-sm leading-relaxed flex-1 line-clamp-3">
                {post.data.description}
              </p>
            )}

            <div class="mt-5 text-school-500 font-semibold text-sm">
              {HOME.news.readMore}
            </div>
          </a>
        ))}
      </div>

    </div>

    <Footer />
  </body>
</html>
