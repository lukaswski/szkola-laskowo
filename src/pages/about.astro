---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { ABOUT_PAGE } from '../content';

const dokumenty = [
  { nazwa: 'Statut szkoły', file: '/dokumenty/statut.pdf' },
  { nazwa: 'Regulamin ucznia', file: '/dokumenty/regulamin-ucznia.pdf' },
  { nazwa: 'Program wychowawczo-profilaktyczny', file: '/dokumenty/program-wychowawczy.pdf' },
  { nazwa: 'Plan pracy szkoły', file: '/dokumenty/plan-pracy.pdf' },
  { nazwa: 'Procedury bezpieczeństwa', file: '/dokumenty/procedury-bezpieczenstwa.pdf' },
  { nazwa: 'Zgoda na przetwarzanie danych (RODO)', file: '/dokumenty/rodo.pdf' },
];
---

<html lang="pl">
  <head>
    <BaseHead title={ABOUT_PAGE.meta.title} description={ABOUT_PAGE.meta.description} />
  </head>
  <body>
    <Header />

    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">

      <div class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-school-500 mb-2">Rok szkolny 2025/2026</p>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-school-900 leading-tight">{ABOUT_PAGE.meta.title}</h1>
        <p class="mt-3 text-school-600 max-w-xl">Dokumenty szkolne — statuty, regulaminy i inne materiały do pobrania.</p>
      </div>

      <!-- TODO: odkomentować gdy dokumenty będą gotowe
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 sm:gap-4 mb-14" id="doc-grid">
        {dokumenty.map((d) => (
          <button
            data-file={d.file}
            data-nazwa={d.nazwa}
            class="doc-btn group text-left rounded-xl border border-school-200 bg-white hover:border-school-400 hover:shadow-md transition-all duration-200 px-4 py-3 flex items-center gap-3"
          >
            <div class="w-8 h-8 rounded-lg bg-school-50 group-hover:bg-school-100 flex items-center justify-center shrink-0 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-school-600">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
