---
import Layout from '../layouts/BlogPost.astro';
import { ABOUT_PAGE, CONTACT } from '../content';
---

<Layout
  title={ABOUT_PAGE.meta.title}
  description={ABOUT_PAGE.meta.description}
  pubDate={new Date('2024-09-01')}
>
  <p>{ABOUT_PAGE.intro}</p>

  <h2>{ABOUT_PAGE.mission.heading}</h2>
  <p>{ABOUT_PAGE.mission.body}</p>

  <h2>{ABOUT_PAGE.staff.heading}</h2>
  <p>
    Szkołą kieruje dyrektor <strong>{ABOUT_PAGE.staff.directorName}</strong>. {ABOUT_PAGE.staff.body}
  </p>
  <p>Organ prowadzący: {ABOUT_PAGE.organizer}</p>

  <h2>{ABOUT_PAGE.contact.heading}</h2>
  <ul>
    <li>Adres: {CONTACT.addressLine1}, {CONTACT.addressLine2}</li>
    <li>Telefon: {CONTACT.phone}</li>
    <li>E-mail: <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></li>
    <li>Godziny pracy sekretariatu: {CONTACT.hours}</li>
  </ul>
</Layout>
