---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const miesiac = [
  {
    name: 'Październik 2025',
    dni: [
      { termin: '13.10.2025', nazwa: 'Dzień wolny od zajęć dydaktycznych' },
      { termin: '14.10.2025', nazwa: 'Dzień wolny od zajęć dydaktycznych' },
    ],
  },
  {
    name: 'Listopad 2025',
    dni: [
      { termin: '01.11.2025', nazwa: 'Wszystkich Świętych' },
      { termin: '10.11.2025', nazwa: 'Dzień wolny od zajęć dydaktycznych' },
      { termin: '11.11.2025', nazwa: 'Narodowe Święto Niepodległości' },
    ],
  },
  {
    name: 'Grudzień 2025',
    dni: [
      { termin: '22.12.2025 – 31.12.2025', nazwa: 'Zimowa przerwa świąteczna' },
      { termin: '24.12.2025', nazwa: 'Wigilia Bożego Narodzenia' },
      { termin: '25.12.2025', nazwa: 'Boże Narodzenie (pierwszy dzień)' },
      { termin: '26.12.2025', nazwa: 'Boże Narodzenie (drugi dzień)' },
    ],
  },
  {
    name: 'Styczeń 2026',
    dni: [
      { termin: '01.01.2026', nazwa: 'Nowy Rok' },
      { termin: '02.01.2026', nazwa: 'Dzień wolny od zajęć dydaktycznych' },
      { termin: '05.01.2026', nazwa: 'Dzień wolny od zajęć dydaktycznych' },
      { termin: '06.01.2026', nazwa: 'Trzech Króli' },
    ],
  },
  {
    name: 'Luty 2026',
    dni: [
      { termin: '02.02.2026 – 15.02.2026', nazwa: 'Ferie zimowe' },
    ],
  },
  {
    name: 'Kwiecień 2026',
    dni: [
      { termin: '02.04.2026 – 07.04.2026', nazwa: 'Wiosenna przerwa świąteczna' },
      { termin: '05.04.2026', nazwa: 'Wielkanoc' },
      { termin: '06.04.2026', nazwa: 'Poniedziałek Wielkanocny' },
    ],
  },
  {
    name: 'Maj 2026',
    dni: [
      { termin: '01.05.2026', nazwa: 'Międzynarodowe Święto Pracy' },
      { termin: '03.05.2026', nazwa: 'Święto Konstytucji 3 Maja' },
      { termin: '11.05.2026', nazwa: 'Egzamin ósmoklasisty z języka polskiego' },
      { termin: '12.05.2026', nazwa: 'Egzamin ósmoklasisty z matematyki' },
      { termin: '13.05.2026', nazwa: 'Egzamin ósmoklasisty z języka angielskiego' },
      { termin: '24.05.2026', nazwa: 'Zielone Świątki' },
    ],
  },
  {
    name: 'Czerwiec 2026',
    dni: [
      { termin: '04.06.2026', nazwa: 'Boże Ciało' },
      { termin: '05.06.2026', nazwa: 'Dzień wolny od zajęć dydaktycznych' },
      { termin: '27.06.2026 – 31.08.2026', nazwa: 'Ferie letnie' },
    ],
  },
  {
    name: 'Sierpień 2026',
    dni: [
      { termin: '15.08.2026', nazwa: 'Wniebowzięcie Najświętszej Maryi Panny' },
    ],
  },
];

const iconCalendar = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`;
---

<html lang="pl">
  <head>
    <BaseHead title="Kalendarz dni wolnych" description="Kalendarz dni wolnych od zajęć dydaktycznych na rok szkolny 2025/2026." />
  </head>
  <body>
    <Header />

    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">

      <div class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-school-500 mb-2">Rok szkolny 2025/2026</p>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-school-900 leading-tight">Kalendarz dni wolnych</h1>
        <p class="mt-3 text-school-600 max-w-xl">Dni wolne od zajęć dydaktycznych, święta i przerwy w roku szkolnym 2025/2026.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 items-start">
        {miesiac.map((m) => (
          <div>
            <h2 class="text-base font-bold text-school-700 uppercase tracking-widest mb-3">{m.name}</h2>
            <div class="rounded-xl border border-school-200 overflow-hidden">
              {m.dni.map((d, i) => (
                <div class={`flex items-center gap-4 px-5 py-3.5 ${i % 2 === 0 ? 'bg-white' : 'bg-school-50/50'} ${i < m.dni.length - 1 ? 'border-b border-school-100' : ''}`}>
                  <div class="w-8 h-8 rounded-lg bg-school-100 flex items-center justify-center shrink-0 text-school-600">
                    <Fragment set:html={iconCalendar} />
                  </div>
                  <div class="flex-1 min-w-0">
                    <span class="block text-sm font-semibold text-school-800 tabular-nums">{d.termin}</span>
                    <span class="block text-sm text-school-600 mt-0.5">{d.nazwa}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>

    <Footer />
  </body>
</html>
